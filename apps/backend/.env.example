# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# MongoDB
MONGODB_URI=mongodb://<app_user>:<app_pass>@localhost:27017/<db>?authSource=<db>

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace-with-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex-string

# PayMongo
PAYMONGO_SECRET_KEY=sk_test_replace_with_your_key
PAYMONGO_WEBHOOK_SECRET=whsk_replace_with_your_webhook_secret

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Feature flags — set to "false" to disable (anything else = enabled)
FEATURE_PAYMENTS_ENABLED=true
FEATURE_LOYALTY_POINTS_ENABLED=true
FEATURE_REVIEWS_ENABLED=true
FEATURE_PROMOTIONS_ENABLED=true
FEATURE_MAINTENANCE_MODE=false